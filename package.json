    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "latest",
    "@capawesome/capacitor-android-edge-to-edge-support": "^8.0.8",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@imagekit/react": "^5.0.2",
