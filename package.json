{
  "name": "thunder-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "npm run build:web",
    "build:web": "tsc -b && vite build --base=/app",
    "build:mobile": "tsc -b && vite build --mode mobile && npx cap sync",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
